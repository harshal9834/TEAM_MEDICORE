# ============================================================
# Backend Environment Variables (.env in project root)
# DO NOT commit this file — add to .gitignore
# ============================================================

NODE_ENV=production
PORT=10000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/gofarm?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_long_random_jwt_secret_here

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret

# Groq AI
GROQ_API_KEY=your_groq_api_key

# Firebase Admin (use env vars instead of JSON file on Render)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com

# Weather API
WEATHER_API_KEY=your_openweathermap_api_key

# Hugging Face
HUGGING_FACE_API_KEY=your_hf_api_key

# Frontend URL (your Vercel domain, comma-separated if multiple)
CLIENT_URL=https://gofarm.vercel.app

# ============================================================
# Frontend Environment Variables (client/.env)
# ============================================================
REACT_APP_API_URL=https://gofarm-api.onrender.com/api